architecture:
  word_size: 4
  block_size: 16    # 4-bit offset → addresses 0x40 apart = different blocks, same set
  write_back: true

cache_1:
  blocks: 4
  associativity: 2  # 2-way → 2 sets, easy to reason about
  hit_time: 1

mem:
  hit_time: 1000    # large gap makes hits/misses obvious in timing
